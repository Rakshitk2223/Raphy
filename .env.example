# Raphael Configuration
# Copy this file to .env and modify as needed

# Server settings
HOST=127.0.0.1
PORT=8080
DEBUG=false

# LLM Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Available models (change based on your needs):
#   - qwen2.5:7b-instruct-q5_K_M  (default, good quality, slower)
#   - qwen2.5:3b-instruct         (faster, slightly lower quality)
#   - phi3.5:3.8b                 (good balance)
#   - gemma2:2b                   (fastest, basic quality)
OLLAMA_MODEL=qwen2.5:7b-instruct-q5_K_M

# Speech-to-Text (Whisper) Configuration
# Available models: large-v3, medium, small, base, tiny
#   - large-v3: Best accuracy, slowest (~3-5s)
#   - medium: Good accuracy, faster (~1-2s)
#   - small: Decent accuracy, fast (~0.5-1s)
STT_MODEL=large-v3

# Device for STT: cuda, cpu, auto
STT_DEVICE=auto

# Compute type: float16, int8, int8_float16, auto
STT_COMPUTE_TYPE=auto

# TTS Configuration
# Enable streaming TTS (speak while generating)
TTS_STREAMING=true

# Paths
DATA_DIR=data
MODELS_DIR=models

# Conversation history limit
MAX_CONVERSATION_HISTORY=20
